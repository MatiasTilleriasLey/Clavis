# Copiar a .env y rellenar. NO committear .env (ver .gitignore).
# Generar SECRET_KEY con:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-genera-uno-con-el-comando-de-arriba

# Postgres (coincide con docker-compose.yml)
DATABASE_URL=postgresql+psycopg://clavis:clavis@localhost:5432/clavis

# Redis (cola de jobs — pasos posteriores)
REDIS_URL=redis://localhost:6379/0

# Flask
FLASK_DEBUG=0

# URL base para armar links en los mails (el worker no tiene request context).
BASE_URL=https://127.0.0.1:8443

# MuseScore para export PDF (lo instala scripts/install_ml.sh). Path al AppRun del AppImage.
MSCORE_BIN=

# NOTA: el SMTP ya no se configura acá. Lo configura el admin desde el panel (Admin → SMTP),
# se guarda en la base de datos. En dev podés apuntarlo a Mailpit (host=localhost, puerto=1026).
